<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>EXPO Admin Dashboard</title>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

<style>
body{font-family:Arial;background:#f4f4f4;margin:0;}
.header{background:#0d6efd;color:#fff;padding:15px;text-align:center;}
.container{padding:20px;}
.card{background:#fff;padding:15px;margin-bottom:15px;border-radius:8px;}
input{display:block;width:100%;padding:10px;margin:8px 0;}
button{padding:10px 15px;background:#0d6efd;color:#fff;border:none;border-radius:5px;cursor:pointer;}
button:hover{background:#084298;}
table{width:100%;border-collapse:collapse;margin-top:10px;}
td,th{border:1px solid #ddd;padding:8px;}
#dashboard{display:none;}
#loginBox{max-width:300px;margin:80px auto;background:#fff;padding:20px;border-radius:10px;}
</style>
</head>

<body>

<div id="loginBox">
<h2>Admin Login</h2>
<input type="email" id="email" placeholder="Email">
<input type="password" id="password" placeholder="Password">
<button onclick="loginAdmin()">Login</button>
<p id="msg" style="color:red;"></p>
</div>

<div id="dashboard">

<div class="header">
<h2>EXPO Admin Dashboard</h2>
<button onclick="logout()" style="float:right;background:red;">Logout</button>
</div>

<div class="container">

<div class="card">
<h3>Stats</h3>
<p>Users: <span id="users">0</span></p>
<p>Deposits Pending: <span id="deposits">0</span></p>
<p>Withdrawals Pending: <span id="withdrawals">0</span></p>
</div>

<div class="card">
<h3>Deposits</h3>
<table>
<thead><tr><th>User</th><th>Amount</th><th>Action</th></tr></thead>
<tbody id="depositTable"></tbody>
</table>
</div>

<div class="card">
<h3>Withdrawals</h3>
<table>
<thead><tr><th>User</th><th>Amount</th><th>Action</th></tr></thead>
<tbody id="withdrawTable"></tbody>
</table>
</div>

</div>
</div>

<script>
// ================= SUPABASE =================
const supabaseUrl = "https://ueylvupimetgerzlygco.supabase.co";
const supabaseKey = "YOUR_SUPABASE_ANON_KEY"; // PUT YOUR REAL KEY HERE

const client = supabase.createClient(supabaseUrl, supabaseKey);

const ADMIN_EMAIL = "expoinvestiment@gmail.com";

// ================= LOGIN =================
async function loginAdmin(){

  const email = document.getElementById("email").value;
  const password = document.getElementById("password").value;

  const { data, error } = await client.auth.signInWithPassword({
    email,
    password
  });

  if(error){
    document.getElementById("msg").innerText = error.message;
    return;
  }

  if(email !== ADMIN_EMAIL){
    document.getElementById("msg").innerText = "Not authorized admin!";
    await client.auth.signOut();
    return;
  }

  document.getElementById("loginBox").style.display = "none";
  document.getElementById("dashboard").style.display = "block";

  loadData();
  setupRealtime();
}

// ================= LOGOUT =================
async function logout(){
  await client.auth.signOut();
  location.reload();
}

// ================= LOAD DATA =================
async function loadData(){

  const users = await client.from("users").select("*");
  const deposits = await client.from("deposits").select("*").eq("status","pending");
  const withdrawals = await client.from("withdrawals").select("*").eq("status","pending");

  document.getElementById("users").innerText = users.data.length;
  document.getElementById("deposits").innerText = deposits.data.length;
  document.getElementById("withdrawals").innerText = withdrawals.data.length;

  renderDeposits(deposits.data);
  renderWithdrawals(withdrawals.data);
}

// ================= RENDER =================
function renderDeposits(data){
  let table = document.getElementById("depositTable");
  table.innerHTML = "";

  data.forEach(d=>{
    table.innerHTML += `
      <tr>
        <td>${d.user_email}</td>
        <td>${d.amount}</td>
        <td>
          <button onclick="updateDeposit('${d.id}','approved')">Approve</button>
          <button onclick="updateDeposit('${d.id}','rejected')">Reject</button>
        </td>
      </tr>
    `;
  });
}

function renderWithdrawals(data){
  let table = document.getElementById("withdrawTable");
  table.innerHTML = "";

  data.forEach(d=>{
    table.innerHTML += `
      <tr>
        <td>${d.user_email}</td>
        <td>${d.amount}</td>
        <td>
          <button onclick="updateWithdrawal('${d.id}','approved')">Approve</button>
          <button onclick="updateWithdrawal('${d.id}','rejected')">Reject</button>
        </td>
      </tr>
    `;
  });
}

// ================= ACTIONS =================
async function updateDeposit(id,status){
  await client.from("deposits").update({status}).eq("id",id);
  loadData();
}

async function updateWithdrawal(id,status){
  await client.from("withdrawals").update({status}).eq("id",id);
  loadData();
}

// ================= REAL TIME =================
function setupRealtime(){

  client.channel("deposits-changes")
  .on("postgres_changes",{event:"*",schema:"public",table:"deposits"},()=>{
    loadData();
  })
  .subscribe();

  client.channel("withdrawals-changes")
  .on("postgres_changes",{event:"*",schema:"public",table:"withdrawals"},()=>{
    loadData();
  })
  .subscribe();
}

</script>

</body>
</html>